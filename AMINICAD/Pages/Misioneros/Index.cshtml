@page
@model AMINICAD.Pages.Misioneros.IndexModel

@using System.Globalization

@{
    ViewData["Title"] = "Misioneros y fondos";

    var cultura = CultureInfo.GetCultureInfo("es-NI");
    var tipos = Model.TiposMision
        .OrderByDescending(x => x.Saldo)
        .ThenBy(x => x.TipoMision)
        .ToList();
    var tipoSeleccionado = Model.TipoMisionSeleccionado;
    var registros = Model.Misioneros
        .OrderByDescending(x => x.Saldo)
        .ThenBy(x => x.Misionero)
        .ToList();

    string FormatearDinero(decimal valor) =>
        $"C$ {valor.ToString("N2", cultura)}";

    string FormatearPorcentaje(decimal valor) =>
        $"{valor.ToString("N1", cultura)}%";

    string ClaseEstado(string estado) =>
        estado switch
        {
            "Saldo negativo" => "misionero-status-negative",
            "Conciliado" => "misionero-status-balanced",
            "Sin movimiento" => "misionero-status-empty",
            _ => "misionero-status-pending"
        };

    string TextoEstado(string estado) =>
        estado switch
        {
            "Saldo negativo" => "Entrega superior al aporte",
            "Conciliado" => "Sin disponible",
            "Sin movimiento" => "Sin movimiento",
            _ => "Disponible"
        };

    string IconoTipo(string tipoMision)
    {
        var texto = tipoMision.ToUpperInvariant();

        if (texto.Contains("EXTR"))
            return "bi-globe-americas";

        if (texto.Contains("CASTILLO"))
            return "bi-people";

        return "bi-building";
    }
}

<div class="dashboard-container misioneros-page">
    <div class="page-header">
        <div>
            <div class="page-pretitle">Portafolio financiero</div>
            <h1 class="page-title">Misioneros y fondos</h1>
            <p class="page-description">
                Aportes recibidos, entregas realizadas y fondos disponibles para desembolso por tipo de misión.
            </p>
        </div>

        <div class="page-actions">
            <div class="dashboard-period">
                <i class="bi bi-clock-history"></i>
                <div>
                    <span>Período consultado</span>
                    <strong>Histórico acumulado</strong>
                    <small>Todos los movimientos registrados</small>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.MensajeError))
    {
        <section class="dashboard-card">
            <div class="dashboard-card-body">
                <div class="quality-warning mt-0">
                    <i class="bi bi-exclamation-triangle"></i>
                    <div>
                        <strong>No fue posible cargar el módulo</strong>
                        <span>@Model.MensajeError</span>
                    </div>
                </div>
            </div>
        </section>
    }
    else if (!Model.TieneDatos)
    {
        <section class="dashboard-card">
            <div class="dashboard-card-body">
                <div class="no-data show py-5">
                    <div class="no-data-icon"><i class="bi bi-person-x"></i></div>
                    <strong>No hay registros disponibles</strong>
                    <span>No se encontraron tipos de misión o fondos administrados.</span>
                </div>
            </div>
        </section>
    }
    else
    {
        <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6 col-xl-3">
                <article class="kpi-card" style="--kpi-accent:#1f2758; --kpi-soft:#eef0f8;">
                    <div class="kpi-card-body">
                        <div class="kpi-icon"><i class="bi bi-person-badge"></i></div>
                        <div class="kpi-content">
                            <div class="kpi-label">Registros administrados</div>
                            <div class="kpi-value">@Model.Resumen.CantidadMisioneros.ToString("N0", cultura)</div>
                            <div class="kpi-note">
                                @Model.Resumen.CantidadConMovimiento.ToString("N0", cultura) con movimientos
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <article class="kpi-card" style="--kpi-accent:#1769aa; --kpi-soft:#e9f3fb;">
                    <div class="kpi-card-body">
                        <div class="kpi-icon"><i class="bi bi-cash-stack"></i></div>
                        <div class="kpi-content">
                            <div class="kpi-label">Aportes recibidos</div>
                            <div class="kpi-value kpi-value-responsive">@FormatearDinero(Model.Resumen.TotalIngresos)</div>
                            <div class="kpi-note">Total aportado históricamente</div>
                        </div>
                    </div>
                </article>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <article class="kpi-card" style="--kpi-accent:#16803c; --kpi-soft:#eaf7ef;">
                    <div class="kpi-card-body">
                        <div class="kpi-icon"><i class="bi bi-wallet2"></i></div>
                        <div class="kpi-content">
                            <div class="kpi-label">Disponible para desembolso</div>
                            <div class="kpi-value kpi-value-responsive">@FormatearDinero(Model.Resumen.SaldoTotal)</div>
                            <div class="kpi-note positive">
                                @Model.Resumen.CantidadConSaldo.ToString("N0", cultura) registros con disponibilidad
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            <div class="col-12 col-sm-6 col-xl-3">
                <article class="kpi-card" style="--kpi-accent:#d8292f; --kpi-soft:#fdeced;">
                    <div class="kpi-card-body">
                        <div class="kpi-icon"><i class="bi bi-exclamation-triangle"></i></div>
                        <div class="kpi-content">
                            <div class="kpi-label">Entregas superiores a aportes</div>
                            <div class="kpi-value">@Model.Resumen.CantidadSaldoNegativo.ToString("N0", cultura)</div>
                            <div class="kpi-note negative">Requieren revisión y conciliación</div>
                        </div>
                    </div>
                </article>
            </div>
        </div>

        <section class="dashboard-card mb-3">
            <header class="dashboard-card-header">
                <div class="card-heading">
                    <h2>Distribución por tipo de misión</h2>
                    <p>Selecciona un tipo para consultar su detalle individual.</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (Model.IdTipoMision.HasValue)
                    {
                        <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">
                            Limpiar selección
                        </a>
                    }
                    <span class="card-badge">@tipos.Count.ToString("N0", cultura) grupos</span>
                </div>
            </header>

            <div class="dashboard-card-body">
                <div class="mision-type-grid" aria-label="Tipos de misión">
                    @for (var indice = 0; indice < tipos.Count; indice++)
                    {
                        var tipo = tipos[indice];
                        var activo = Model.IdTipoMision == tipo.IdTipoMision;
                        var porcentajeBarra = Math.Clamp(tipo.PorcentajeSaldo, 0m, 100m);

                        <a asp-page="./Index"
                           asp-route-IdTipoMision="@tipo.IdTipoMision"
                           class="mision-type-card tone-@((indice % 3) + 1) @(activo ? "active" : string.Empty)"
                           aria-current="@(activo ? "true" : null)">
                            <div class="mision-type-card-top">
                                <span class="mision-type-icon"><i class="bi @IconoTipo(tipo.TipoMision)"></i></span>
                                <span class="mision-type-count">
                                    @tipo.CantidadMisioneros.ToString("N0", cultura) registros
                                </span>
                            </div>
                            <div class="mision-type-name">@tipo.TipoMision</div>
                            <div class="mision-type-balance">@FormatearDinero(tipo.Saldo)</div>
                            <div class="mision-type-caption">
                                Disponible para desembolso · @FormatearPorcentaje(tipo.PorcentajeSaldo) del total
                            </div>
                            <div class="mision-type-progress" aria-hidden="true">
                                <span style="width:@porcentajeBarra.ToString("0.##", CultureInfo.InvariantCulture)%"></span>
                            </div>
                            <div class="mision-type-footer">
                                <span>@tipo.CantidadConSaldo.ToString("N0", cultura) con disponibilidad</span>
                                <span class="@(tipo.CantidadSaldoNegativo > 0 ? "text-danger" : string.Empty)">
                                    @tipo.CantidadSaldoNegativo.ToString("N0", cultura) entregas excedidas
                                </span>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </section>

        @if (!Model.IdTipoMision.HasValue)
        {
            <section class="dashboard-card">
                <div class="dashboard-card-body">
                    <div class="no-data show py-5">
                        <div class="no-data-icon"><i class="bi bi-funnel"></i></div>
                        <strong>Selecciona un tipo de misión</strong>
                        <span>El detalle individual se consulta únicamente para el grupo seleccionado.</span>
                    </div>
                </div>
            </section>
        }
        else if (tipoSeleccionado is null)
        {
            <section class="dashboard-card">
                <div class="dashboard-card-body">
                    <div class="quality-warning mt-0">
                        <i class="bi bi-exclamation-triangle"></i>
                        <div>
                            <strong>Tipo de misión no válido</strong>
                            <span>Selecciona uno de los grupos disponibles.</span>
                        </div>
                    </div>
                </div>
            </section>
        }
        else
        {
            <section class="dashboard-card">
                <header class="dashboard-card-header misioneros-table-header">
                    <div class="card-heading">
                        <h2>@tipoSeleccionado.TipoMision</h2>
                        <p>
                            @FormatearDinero(tipoSeleccionado.TotalIngresos) aportados ·
                            @FormatearDinero(tipoSeleccionado.TotalSalidas) en entregas realizadas ·
                            @FormatearPorcentaje(tipoSeleccionado.PorcentajeEjecucion) entregado
                        </p>
                    </div>
                    <div class="misioneros-table-actions">
                        <label class="misioneros-search" for="buscar-misionero">
                            <i class="bi bi-search"></i>
                            <input type="search"
                                   id="buscar-misionero"
                                   class="form-control form-control-sm"
                                   placeholder="Buscar nombre o código..."
                                   autocomplete="off"
                                   data-misionero-search />
                        </label>
                        <span class="card-badge" data-result-count>
                            @registros.Count.ToString("N0", cultura) registros
                        </span>
                    </div>
                </header>

                <div class="dashboard-card-body p-0">
                    @if (!Model.TieneDetalle)
                    {
                        <div class="no-data show py-5">
                            <div class="no-data-icon"><i class="bi bi-person-x"></i></div>
                            <strong>Sin detalle disponible</strong>
                            <span>El procedimiento no devolvió registros para este tipo de misión.</span>
                        </div>
                    }
                    else
                    {
                        <div class="dashboard-table-wrapper">
                            <table class="dashboard-table table align-middle mb-0" id="tabla-misioneros">
                                <thead>
                                    <tr>
                                        <th>Beneficiario o fondo</th>
                                        <th class="text-end">Aportes recibidos</th>
                                        <th class="text-end">Entregas realizadas</th>
                                        <th class="text-end">Disponible para desembolso</th>
                                        <th>% entregado</th>
                                        <th>Estado</th>
                                        <th class="text-end">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var registro in registros)
                                    {
                                        var porcentajeVisual = Math.Clamp(registro.PorcentajeEjecucion, 0m, 100m);
                                        var textoBusqueda = $"{registro.IdMisionero} {registro.Misionero}".ToLowerInvariant();

                                        <tr data-misionero-row data-search="@textoBusqueda">
                                            <td>
                                                <div class="table-entity">
                                                    <span class="entity-avatar entity-avatar-blue">
                                                        @registro.Misionero.Substring(0, 1).ToUpperInvariant()
                                                    </span>
                                                    <div>
                                                        <div class="entity-name">@registro.Misionero</div>
                                                        <div class="table-subtitle">Código @registro.IdMisionero.ToString("D3", cultura)</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end">@FormatearDinero(registro.Ingreso)</td>
                                            <td class="text-end">@FormatearDinero(registro.Salida)</td>
                                            <td class="text-end table-money @(registro.Saldo < 0 ? "text-danger" : string.Empty)">
                                                @FormatearDinero(registro.Saldo)
                                            </td>
                                            <td>
                                                <div class="misionero-execution">
                                                    <span>@FormatearPorcentaje(registro.PorcentajeEjecucion)</span>
                                                    <div class="misionero-execution-track">
                                                        <span style="width:@porcentajeVisual.ToString("0.##", CultureInfo.InvariantCulture)%"></span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="misionero-status @ClaseEstado(registro.EstadoSaldo)">
                                                    @TextoEstado(registro.EstadoSaldo)
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <a asp-page="./Detalle"
                                                   asp-route-IdMisionero="@registro.IdMisionero"
                                                   asp-route-Anio="@DateTime.Today.Year"
                                                   class="btn btn-sm btn-outline-primary">
                                                    Ver ficha
                                                    <i class="bi bi-arrow-right ms-1"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                    <tr data-empty-row hidden>
                                        <td colspan="6" class="table-empty">No se encontraron coincidencias.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </section>
        }
    }
</div>

@section Scripts
{
    <script>
        (() => {
            const input = document.querySelector("[data-misionero-search]");
            const table = document.getElementById("tabla-misioneros");

            if (!input || !table) return;

            const normalizar = (texto) =>
                (texto ?? "")
                    .toString()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .toLowerCase()
                    .trim();

            input.addEventListener("input", () => {
                const termino = normalizar(input.value);
                const rows = Array.from(table.querySelectorAll("[data-misionero-row]"));
                let visibles = 0;

                rows.forEach((row) => {
                    const mostrar = !termino || normalizar(row.dataset.search).includes(termino);
                    row.hidden = !mostrar;
                    if (mostrar) visibles++;
                });

                const emptyRow = table.querySelector("[data-empty-row]");
                if (emptyRow) emptyRow.hidden = visibles !== 0;

                const badge = document.querySelector("[data-result-count]");
                if (badge) badge.textContent = `${visibles.toLocaleString("es-NI")} registros`;
            });
        })();
    </script>
}
