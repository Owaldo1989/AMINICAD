@{
    var currentPage =
        ViewContext.RouteData.Values["page"]?.ToString()
        ?? string.Empty;

    var title =
        ViewData["Title"]?.ToString()
        ?? "AMINICAD";

    var userName =
        User?.Identity?.IsAuthenticated == true
            ? User.Identity.Name ?? "Administrador"
            : "Administrador";

    string ActivePage(string page)
    {
        return string.Equals(
            currentPage,
            page,
            StringComparison.OrdinalIgnoreCase)
                ? "active"
                : string.Empty;
    }
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <meta name="theme-color"
          content="#1f2758" />

    <title>@title - AMINICAD</title>

    <script type="importmap"></script>

    <link rel="preconnect"
          href="https://fonts.googleapis.com" />

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/AMINICAD.styles.css"
          asp-append-version="true" />
</head>

<body>

    <div class="app-shell">

        <!-- SIDEBAR -->
        <aside class="app-sidebar"
               id="appSidebar">

            <div class="sidebar-header">

                <a asp-page="/Index"
                   class="brand">

                    <span class="brand-logo">
                        <img src="~/img/logo-aminicad.jpeg"
                             alt="Logo de AMINICAD" />
                    </span>

                    <span class="brand-copy">
                        <strong>AMINICAD</strong>
                        <small>Agencia Misionera Nicaragüense A/D</small>
                    </span>

                </a>

                <button type="button"
                        class="sidebar-close d-lg-none"
                        id="sidebarClose"
                        aria-label="Cerrar menú">

                    <i class="bi bi-x-lg"></i>

                </button>

            </div>

            <div class="sidebar-body">

                <div class="nav-caption">
                    PRINCIPAL
                </div>

                <a asp-page="/Index"
                   class="sidebar-link @ActivePage("/Index")">

                    <span class="sidebar-icon">
                        <i class="bi bi-grid-1x2-fill"></i>
                    </span>

                    <span>Dashboard</span>

                </a>

                <div class="nav-caption">
                    GESTIÓN
                </div>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-cash-stack"></i>
                    </span>
                    <span>Ingresos</span>
                </span>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-person-badge"></i>
                    </span>
                    <span>Misioneros</span>
                </span>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-bank2"></i>
                    </span>
                    <span>Iglesias y donantes</span>
                </span>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-geo-alt"></i>
                    </span>
                    <span>Regiones y distritos</span>
                </span>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-wallet2"></i>
                    </span>
                    <span>Liquidaciones</span>
                </span>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-people"></i>
                    </span>
                    <span>Movilizadores</span>
                </span>

                <div class="nav-caption">
                    ANÁLISIS
                </div>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-bar-chart-line"></i>
                    </span>
                    <span>Reportes</span>
                </span>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-clock-history"></i>
                    </span>
                    <span>Auditoría</span>
                </span>

                <div class="nav-caption">
                    SISTEMA
                </div>

                <span class="sidebar-link disabled">
                    <span class="sidebar-icon">
                        <i class="bi bi-gear"></i>
                    </span>
                    <span>Configuración</span>
                </span>

            </div>

            <div class="sidebar-footer">

                <div class="sidebar-user">

                    <div class="user-avatar">
                        AD
                    </div>

                    <div class="user-info">
                        <strong>@userName</strong>
                        <span>Administrador</span>
                    </div>

                    <button type="button"
                            class="user-options"
                            title="Opciones">

                        <i class="bi bi-three-dots-vertical"></i>

                    </button>

                </div>

            </div>

        </aside>

        <div class="sidebar-overlay"
             id="sidebarOverlay">
        </div>

        <!-- CONTENIDO PRINCIPAL -->
        <div class="app-main">

            <header class="app-topbar">

                <div class="topbar-left">

                    <button type="button"
                            class="topbar-menu-button d-lg-none"
                            id="sidebarOpen"
                            aria-label="Abrir menú">

                        <i class="bi bi-list"></i>

                    </button>

                    <div class="topbar-product">
                        <span>Portal administrativo</span>
                        <small>Información financiera y misionera</small>
                    </div>

                </div>

                <div class="topbar-actions">

                    <button type="button"
                            class="topbar-icon-button"
                            onclick="window.location.reload()"
                            title="Actualizar">

                        <i class="bi bi-arrow-clockwise"></i>

                    </button>

                    <button type="button"
                            class="topbar-icon-button notification-button"
                            title="Notificaciones">

                        <i class="bi bi-bell"></i>
                        <span class="notification-dot"></span>

                    </button>

                    <div class="topbar-divider"></div>

                    <div class="topbar-user">

                        <div class="topbar-avatar">
                            AD
                        </div>

                        <div class="topbar-user-copy">
                            <strong>@userName</strong>
                            <span>Administración</span>
                        </div>

                        <i class="bi bi-chevron-down topbar-chevron"></i>

                    </div>

                </div>

            </header>

            <main role="main"
                  class="app-content">

                @RenderBody()

            </main>

            <footer class="app-footer">

                <span>
                    © @DateTime.Today.Year AMINICAD
                </span>

                <span>
                    Agencia Misionera Nicaragüense A/D
                </span>

            </footer>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true">
    </script>

    <script>
        (function () {
        const sidebar = document.getElementById("appSidebar");
        const overlay = document.getElementById("sidebarOverlay");
        const openButton = document.getElementById("sidebarOpen");
        const closeButton = document.getElementById("sidebarClose");

        function openSidebar() {
        sidebar?.classList.add("open");
        overlay?.classList.add("show");
        document.body.classList.add("sidebar-open");
        }

        function closeSidebar() {
        sidebar?.classList.remove("open");
        overlay?.classList.remove("show");
        document.body.classList.remove("sidebar-open");
        }

        openButton?.addEventListener("click", openSidebar);
        closeButton?.addEventListener("click", closeSidebar);
        overlay?.addEventListener("click", closeSidebar);

        document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
        closeSidebar();
        }
        });
        })();
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)

</body>
</html>