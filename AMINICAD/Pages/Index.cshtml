        </div>

        <div class="col-12 col-xxl-6">
            <section class="dashboard-card">
                <header class="dashboard-card-header">
                    <div class="card-heading">
                        <h2>
                            Principales iglesias y aportantes
                        </h2>

                        <p>
                            Aportantes con mayor participación en @etiquetaPeriodo
                        </p>
                    </div>

                    <span class="card-badge">
                        Top @iglesias.Count
                    </span>
                </header>

                <div class="dashboard-table-wrapper">
                    <table class="table dashboard-table dashboard-table-compact mb-0">
                        <thead>
                            <tr>
                                <th>Iglesia / aportante</th>
                                <th>Distrito</th>
                                <th class="text-end">Aportado</th>
