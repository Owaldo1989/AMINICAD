@page
@model AMINICAD.Pages.IndexModel

@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";

    var cultura = CultureInfo.GetCultureInfo("es-NI");

    var resumen = Model.Dashboard.Resumen;
    var calidad = Model.Dashboard.Calidad;

    var mensual = Model.Dashboard.Mensual
        .OrderBy(x => x.Periodo)
        .ToList();

    var distribucion = Model.Dashboard.Distribucion
        .Where(x => x.Monto > 0)
        .OrderByDescending(x => x.Monto)
        .Take(8)
        .ToList();

    var regiones = Model.Dashboard.Regiones
        .Where(x => x.TotalRecaudado > 0)
        .OrderByDescending(x => x.TotalRecaudado)
        .Take(10)
        .ToList();

    var distritos = Model.Dashboard.Distritos
        .Where(x => x.TotalRecaudado > 0)
        .OrderByDescending(x => x.TotalRecaudado)
        .Take(8)
        .ToList();

    var misioneros = Model.Dashboard.Misioneros
        .Where(x => x.TotalBruto > 0)
        .OrderByDescending(x => x.TotalBruto)
        .Take(8)
        .ToList();

    var iglesias = Model.Dashboard.Iglesias
        .Where(x => x.TotalAportado > 0)
        .OrderByDescending(x => x.TotalAportado)
        .Take(8)
        .ToList();

    var mesesConMovimiento = mensual.Count(x => x.TotalBruto > 0);

    var mejorMes = mensual
        .Where(x => x.TotalBruto > 0)
        .OrderByDescending(x => x.TotalBruto)
        .FirstOrDefault();

    var totalIncidencias =
        calidad.RecibosSinIglesia +
        calidad.RecibosSinMisionero +
        calidad.RecibosSinRegion +
        calidad.RecibosSinDistrito +
        calidad.FilasSinConcepto +
        calidad.ConceptosNoClasificados +
        calidad.RecibosDescuadrados;

    string FormatearDinero(decimal valor)
    {
        return $"C$ {valor.ToString("N2", cultura)}";
    }

    string FormatearFecha(DateTime? fecha)
    {
        return fecha.HasValue
            ? fecha.Value.ToString("dd/MM/yyyy", cultura)
            : "Sin fecha";
    }
}

<div class="dashboard-container">

    <!-- ======================================================
         ENCABEZADO
         ====================================================== -->

    <div class="page-header">

        <div>
            <div class="page-pretitle">
                Resumen ejecutivo
            </div>

            <h1 class="page-title">
                Dashboard administrativo
            </h1>

            <p class="page-description">
                Recaudación, distribución de fondos y comportamiento
                de iglesias, regiones y beneficiarios.
            </p>
        </div>

        <div class="page-actions">

            <div class="dashboard-period">

                <i class="bi bi-calendar3"></i>

                <div>
                    <span>Período consultado</span>

                    <strong>
                        01/01/@Model.AnioSeleccionado
                        —
                        31/12/@Model.AnioSeleccionado
                    </strong>
                </div>

            </div>

            <form method="get"
                  class="filter-card">

                <label for="anio">
                    Año
                </label>

                <select id="anio"
                        name="anio"
                        class="form-select"
                        onchange="this.form.submit()">

                    @foreach (var anio in Model.OpcionesAnio)
                    {
                        <option value="@anio"
                                selected="@(anio == Model.AnioSeleccionado
                                                                    ? "selected"
                                                                    : null)">
                            @anio
                        </option>
                    }

                </select>

            </form>

        </div>

    </div>


    <!-- ======================================================
         KPI PRINCIPALES
         ====================================================== -->

    <div class="row g-3 mb-3">

        <div class="col-12 col-sm-6 col-xl-4 col-xxl-2">

            <article class="kpi-card"
                     style="--kpi-accent:#1f2758; --kpi-soft:#eef0f8;">

                <div class="kpi-card-body">

                    <div class="kpi-icon">
                        <i class="bi bi-cash-stack"></i>
                    </div>

                    <div class="kpi-content">

                        <div class="kpi-label">
                            Recaudación bruta
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.TotalBruto)
                        </div>

                        <div class="kpi-note">
                            @resumen.CantidadRecibos.ToString("N0", cultura)
                            recibos registrados
                        </div>

                    </div>

                </div>

            </article>

        </div>


        <div class="col-12 col-sm-6 col-xl-4 col-xxl-2">

            <article class="kpi-card"
                     style="--kpi-accent:#16803c; --kpi-soft:#eaf7ef;">

                <div class="kpi-card-body">

                    <div class="kpi-icon">
                        <i class="bi bi-person-check"></i>
                    </div>

                    <div class="kpi-content">

                        <div class="kpi-label">
                            Neto beneficiarios
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.NetoBeneficiarios)
                        </div>

                        <div class="kpi-note positive">
                            @resumen.PorcentajeNeto.ToString("N2", cultura)%
                            de lo recaudado
                        </div>

                    </div>

                </div>

            </article>

        </div>


        <div class="col-12 col-sm-6 col-xl-4 col-xxl-2">

            <article class="kpi-card"
                     style="--kpi-accent:#d8292f; --kpi-soft:#fdeced;">

                <div class="kpi-card-body">

                    <div class="kpi-icon">
                        <i class="bi bi-pie-chart"></i>
                    </div>

                    <div class="kpi-content">

                        <div class="kpi-label">
                            Retenciones
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.TotalRetenciones)
                        </div>

                        <div class="kpi-note">
                            @resumen.PorcentajeRetenciones.ToString("N2", cultura)%
                            del total
                        </div>

                    </div>

                </div>

            </article>

        </div>


        <div class="col-12 col-sm-6 col-xl-4 col-xxl-2">

            <article class="kpi-card"
                     style="--kpi-accent:#1769aa; --kpi-soft:#e9f3fb;">

                <div class="kpi-card-body">

                    <div class="kpi-icon">
                        <i class="bi bi-bank2"></i>
                    </div>

                    <div class="kpi-content">

                        <div class="kpi-label">
                            Iglesias / aportantes
                        </div>

                        <div class="kpi-value">
                            @resumen.CantidadIglesias.ToString("N0", cultura)
                        </div>

                        <div class="kpi-note">
                            @resumen.CantidadDistritos.ToString("N0", cultura)
                            distritos
                        </div>

                    </div>

                </div>

            </article>

        </div>


        <div class="col-12 col-sm-6 col-xl-4 col-xxl-2">

            <article class="kpi-card"
                     style="--kpi-accent:#7b3fc6; --kpi-soft:#f2ebfb;">

                <div class="kpi-card-body">

                    <div class="kpi-icon">
                        <i class="bi bi-person-vcard"></i>
                    </div>

                    <div class="kpi-content">

                        <div class="kpi-label">
                            Beneficiarios
                        </div>

                        <div class="kpi-value">
                            @resumen.CantidadMisioneros.ToString("N0", cultura)
                        </div>

                        <div class="kpi-note">
                            Misioneros y proyectos
                        </div>

                    </div>

                </div>

            </article>

        </div>


        <div class="col-12 col-sm-6 col-xl-4 col-xxl-2">

            <article class="kpi-card"
                     style="--kpi-accent:#c76b05; --kpi-soft:#fff4df;">

                <div class="kpi-card-body">

                    <div class="kpi-icon">
                        <i class="bi bi-calculator"></i>
                    </div>

                    <div class="kpi-content">

                        <div class="kpi-label">
                            Promedio por aporte
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.PromedioAporte)
                        </div>

                        <div class="kpi-note">
                            Mediana:
                            @FormatearDinero(resumen.MedianaAporte)
                        </div>

                    </div>

                </div>

            </article>

        </div>

    </div>


    <!-- ======================================================
         COMPORTAMIENTO MENSUAL + DISTRIBUCIÓN
         ====================================================== -->

    <div class="row g-3 mb-3">

        <div class="col-12 col-xl-8">

            <section class="dashboard-card">

                <header class="dashboard-card-header">

                    <div class="card-heading">

                        <h2>
                            Comportamiento mensual
                        </h2>

                        <p>
                            Recaudación bruta, neto para beneficiarios
                            y retenciones
                        </p>

                    </div>

                    <div class="card-header-meta">

                        <span class="card-badge">
                            @mesesConMovimiento meses con movimientos
                        </span>

                        @if (mejorMes is not null)
                        {
                            <span class="card-highlight">
                                Mejor mes:
                                <strong>@mejorMes.Mes</strong>
                            </span>
                        }

                    </div>

                </header>

                <div class="dashboard-card-body">

                    <div class="chart-container chart-large">

                        <canvas id="chartComportamientoMensual">
                        </canvas>

                        <div id="emptyComportamiento"
                             class="chart-empty">

                            <div class="chart-empty-icon">
                                <i class="bi bi-graph-up"></i>
                            </div>

                            <strong>
                                No hay información mensual
                            </strong>

                            <span>
                                El procedimiento no devolvió movimientos
                                para @Model.AnioSeleccionado.
                            </span>

                        </div>

                    </div>

                </div>

            </section>

        </div>


        <div class="col-12 col-xl-4">

            <section class="dashboard-card">

                <header class="dashboard-card-header">

                    <div class="card-heading">

                        <h2>
                            Distribución de los fondos
                        </h2>

                        <p>
                            Conceptos aplicados a los recibos
                        </p>

                    </div>

                </header>

                <div class="dashboard-card-body">

                    <div class="distribution-chart">

                        <div class="distribution-canvas">

                            <canvas id="chartDistribucion">
                            </canvas>

                            <div id="emptyDistribucion"
                                 class="chart-empty chart-empty-small">

                                <strong>
                                    Sin distribución
                                </strong>

                            </div>

                        </div>

                        <div class="distribution-total">

                            <span>
                                Total distribuido
                            </span>

                            <strong>
                                @FormatearDinero(resumen.TotalDistribuido)
                            </strong>

                        </div>

                    </div>

                    <div class="distribution-list">

                        @foreach (var item in distribucion.Take(6))
                        {
                            <div class="distribution-row">

                                <div class="distribution-row-copy">

                                    <span class="distribution-marker">
                                    </span>

                                    <div>
                                        <strong>
                                            @item.Concepto
                                        </strong>

                                        <span>
                                            @item.CantidadRecibos.ToString("N0", cultura)
                                            recibos
                                        </span>
                                    </div>

                                </div>

                                <div class="distribution-row-value">

                                    <strong>
                                        @FormatearDinero(item.Monto)
                                    </strong>

                                    <span>
                                        @item.PorcentajeTotal.ToString("N2", cultura)%
                                    </span>

                                </div>

                            </div>
                        }

                    </div>

                </div>

            </section>

        </div>

    </div>


    <!-- ======================================================
         REGIONES + CONTROL DE CALIDAD
         ====================================================== -->

    <div class="row g-3 mb-3">

        <div class="col-12 col-xl-8">

            <section class="dashboard-card">

                <header class="dashboard-card-header">

                    <div class="card-heading">

                        <h2>
                            Recaudación por región
                        </h2>

                        <p>
                            Participación territorial dentro del período
                        </p>

                    </div>

                    <span class="card-badge">
                        @resumen.CantidadRegiones regiones
                    </span>

                </header>

                <div class="dashboard-card-body">

                    <div class="chart-container chart-regions">

                        <canvas id="chartRegiones">
                        </canvas>

                        <div id="emptyRegiones"
                             class="chart-empty">

                            <div class="chart-empty-icon">
                                <i class="bi bi-geo-alt"></i>
                            </div>

                            <strong>
                                No hay regiones para mostrar
                            </strong>

                        </div>

                    </div>

                </div>

            </section>

        </div>


        <div class="col-12 col-xl-4">

            <section class="dashboard-card">

                <header class="dashboard-card-header">

                    <div class="card-heading">

                        <h2>
                            Calidad de información
                        </h2>

                        <p>
                            Validaciones administrativas del período
                        </p>

                    </div>

                    @if (totalIncidencias > 0)
                    {
                        <span class="badge-status badge-status-warning">
                            @totalIncidencias incidencias
                        </span>
                    }
                    else
                    {
                        <span class="badge-status badge-status-success">
                            Sin incidencias
                        </span>
                    }

                </header>

                <div class="dashboard-card-body">

                    <div class="quality-list">

                        <div class="quality-item">

                            <div class="quality-icon">
                                <i class="bi bi-bank"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin iglesia</span>
                                <strong>@calidad.RecibosSinIglesia</strong>
                            </div>

                        </div>


                        <div class="quality-item">

                            <div class="quality-icon">
                                <i class="bi bi-person-x"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin beneficiario</span>
                                <strong>@calidad.RecibosSinMisionero</strong>
                            </div>

                        </div>


                        <div class="quality-item">

                            <div class="quality-icon">
                                <i class="bi bi-geo"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin región</span>
                                <strong>@calidad.RecibosSinRegion</strong>
                            </div>

                        </div>


                        <div class="quality-item">

                            <div class="quality-icon">
                                <i class="bi bi-signpost-split"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin distrito</span>
                                <strong>@calidad.RecibosSinDistrito</strong>
                            </div>

                        </div>


                        <div class="quality-item">

                            <div class="quality-icon">
                                <i class="bi bi-tags"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Conceptos no clasificados</span>
                                <strong>@calidad.ConceptosNoClasificados</strong>
                            </div>

                        </div>


                        <div class="quality-item quality-item-important">

                            <div class="quality-icon">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos descuadrados</span>
                                <strong>@calidad.RecibosDescuadrados</strong>
                            </div>

                        </div>

                    </div>

                    @if (calidad.RecibosDescuadrados > 0)
                    {
                        <div class="quality-warning">

                            <i class="bi bi-exclamation-circle"></i>

                            <div>
                                <strong>
                                    Diferencia encontrada
                                </strong>

                                <span>
                                    @FormatearDinero(calidad.DiferenciaTotal)
                                </span>
                            </div>

                        </div>
                    }

                </div>

            </section>

        </div>

    </div>


    <!-- ======================================================
         DISTRITOS
         ====================================================== -->

    <section class="dashboard-card mb-3">

        <header class="dashboard-card-header">

            <div class="card-heading">

                <h2>
                    Distritos con mayor recaudación
                </h2>

                <p>
                    Principales resultados territoriales
                </p>

            </div>

            <span class="card-badge">
                Top @distritos.Count
            </span>

        </header>

        <div class="dashboard-table-wrapper">

            <table class="table dashboard-table mb-0">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Distrito</th>
                        <th>Región</th>
                        <th class="text-end">Recaudado</th>
                        <th class="text-end">Recibos</th>
                        <th class="text-end">Iglesias</th>
                        <th class="text-end">Promedio</th>
                        <th>Último aporte</th>
                    </tr>
                </thead>

                <tbody>

                    @if (distritos.Count > 0)
                    {
                        var posicionDistrito = 0;

                        foreach (var distrito in distritos)
                        {
                            posicionDistrito++;

                            <tr>

                                <td>
                                    <span class="ranking-position">
                                        @posicionDistrito
                                    </span>
                                </td>

                                <td>
                                    <div class="entity-name">
                                        @distrito.Distrito
                                    </div>
                                </td>

                                <td>
                                    <span class="table-subtitle">
                                        @distrito.Region
                                    </span>
                                </td>

                                <td class="text-end table-money">
                                    @FormatearDinero(distrito.TotalRecaudado)
                                </td>

                                <td class="text-end">
                                    @distrito.CantidadRecibos.ToString("N0", cultura)
                                </td>

                                <td class="text-end">
                                    @distrito.Iglesias.ToString("N0", cultura)
                                </td>

                                <td class="text-end">
                                    @FormatearDinero(distrito.PromedioAporte)
                                </td>

                                <td>
                                    @FormatearFecha(distrito.UltimoAporte)
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8"
                                class="table-empty">

                                No hay distritos disponibles
                                para el período seleccionado.

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </section>


    <!-- ======================================================
         MISIONEROS E IGLESIAS
         ====================================================== -->

    <div class="row g-3">

        <div class="col-12 col-xxl-6">

            <section class="dashboard-card">

                <header class="dashboard-card-header">

                    <div class="card-heading">

                        <h2>
                            Principales beneficiarios
                        </h2>

                        <p>
                            Misioneros y proyectos con mayor recaudación
                        </p>

                    </div>

                    <span class="card-badge">
                        Top @misioneros.Count
                    </span>

                </header>

                <div class="dashboard-table-wrapper">

                    <table class="table dashboard-table dashboard-table-compact mb-0">

                        <thead>
                            <tr>
                                <th>Beneficiario</th>
                                <th class="text-end">Bruto</th>
                                <th class="text-end">Neto</th>
                                <th class="text-end">Retenciones</th>
                                <th class="text-end">Recibos</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (misioneros.Count > 0)
                            {
                                foreach (var misionero in misioneros)
                                {
                                    <tr>

                                        <td>

                                            <div class="table-entity">

                                                <div class="entity-avatar entity-avatar-blue">
                                                    <i class="bi bi-person"></i>
                                                </div>

                                                <div>
                                                    <div class="entity-name">
                                                        @misionero.Misionero
                                                    </div>

                                                    <span class="table-subtitle">
                                                        @misionero.Iglesias iglesias
                                                    </span>
                                                </div>

                                            </div>

                                        </td>

                                        <td class="text-end table-money">
                                            @FormatearDinero(misionero.TotalBruto)
                                        </td>

                                        <td class="text-end table-money-success">
                                            @FormatearDinero(misionero.Neto)
                                        </td>

                                        <td class="text-end">
                                            @FormatearDinero(misionero.Retenciones)
                                        </td>

                                        <td class="text-end">
                                            @misionero.CantidadRecibos.ToString("N0", cultura)
                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5"
                                        class="table-empty">

                                        No hay beneficiarios disponibles.

                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </section>

        </div>


        <div class="col-12 col-xxl-6">

            <section class="dashboard-card">

                <header class="dashboard-card-header">

                    <div class="card-heading">

                        <h2>
                            Principales iglesias y aportantes
                        </h2>

                        <p>
                            Aportantes con mayor participación
                        </p>

                    </div>

                    <span class="card-badge">
                        Top @iglesias.Count
                    </span>

                </header>

                <div class="dashboard-table-wrapper">

                    <table class="table dashboard-table dashboard-table-compact mb-0">

                        <thead>
                            <tr>
                                <th>Iglesia / aportante</th>
                                <th>Distrito</th>
                                <th class="text-end">Aportado</th>
                                <th class="text-end">Recibos</th>
                                <th class="text-end">Beneficiarios</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (iglesias.Count > 0)
                            {
                                foreach (var iglesia in iglesias)
                                {
                                    <tr>

                                        <td>

                                            <div class="table-entity">

                                                <div class="entity-avatar entity-avatar-red">
                                                    <i class="bi bi-bank"></i>
                                                </div>

                                                <div>
                                                    <div class="entity-name">
                                                        @iglesia.Iglesia
                                                    </div>

                                                    <span class="table-subtitle">
                                                        @iglesia.Region
                                                    </span>
                                                </div>

                                            </div>

                                        </td>

                                        <td>
                                            <span class="table-subtitle">
                                                @iglesia.Distrito
                                            </span>
                                        </td>

                                        <td class="text-end table-money">
                                            @FormatearDinero(iglesia.TotalAportado)
                                        </td>

                                        <td class="text-end">
                                            @iglesia.CantidadRecibos.ToString("N0", cultura)
                                        </td>

                                        <td class="text-end">
                                            @iglesia.MisionerosApoyados.ToString("N0", cultura)
                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5"
                                        class="table-empty">

                                        No hay iglesias disponibles.

                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </section>

        </div>

    </div>

</div>


@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js">
    </script>

    <script>
        (function () {

            const mensual =
                @Html.Raw(JsonSerializer.Serialize(
                        mensual.Select(x => new
                        {
                                x.Mes,
                                Bruto = x.TotalBruto,
                                Neto = x.NetoBeneficiarios,
                                x.Retenciones,
                                x.CantidadRecibos
                        })));

            const distribucion =
                @Html.Raw(JsonSerializer.Serialize(
                        distribucion.Select(x => new
                        {
                                x.Concepto,
                                x.Monto,
                                x.PorcentajeTotal
                        })));

            const regiones =
                @Html.Raw(JsonSerializer.Serialize(
                        regiones.Select(x => new
                        {
                                x.Region,
                                x.TotalRecaudado,
                                x.CantidadRecibos,
                                x.Iglesias
                        })));

            const moneyFormatter =
                new Intl.NumberFormat(
                    "es-NI",
                    {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });

            const compactFormatter =
                new Intl.NumberFormat(
                    "es-NI",
                    {
                        notation: "compact",
                        maximumFractionDigits: 1
                    });

            const colors = {
                primary: "#1f2758",
                primaryLight: "#6470a6",
                red: "#d8292f",
                green: "#16803c",
                orange: "#c76b05",
                blue: "#1769aa",
                purple: "#7b3fc6",
                gray: "#98a2b3",
                grid: "#e8ebf2",
                muted: "#667085"
            };

            const distributionColors = [
                colors.primary,
                colors.red,
                colors.green,
                colors.blue,
                colors.orange,
                colors.purple,
                colors.primaryLight,
                colors.gray
            ];

            function money(value) {
                return `C$ ${moneyFormatter.format(value ?? 0)}`;
            }

            function compactMoney(value) {
                return `C$ ${compactFormatter.format(value ?? 0)}`;
            }

            function showEmpty(canvasId, emptyId) {

                const canvas =
                    document.getElementById(canvasId);

                const empty =
                    document.getElementById(emptyId);

                if (canvas) {
                    canvas.style.display = "none";
                }

                empty?.classList.add("show");
            }

            Chart.defaults.font.family =
                "Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif";

            Chart.defaults.color =
                colors.muted;


            // ==================================================
            // COMPORTAMIENTO MENSUAL
            // ==================================================

            const hasMensual =
                mensual.some(row =>
                    Number(row.Bruto) > 0 ||
                    Number(row.Neto) > 0 ||
                    Number(row.Retenciones) > 0);

            if (!hasMensual) {

                showEmpty(
                    "chartComportamientoMensual",
                    "emptyComportamiento");

            } else {

                const canvas =
                    document.getElementById(
                        "chartComportamientoMensual");

                const context =
                    canvas.getContext("2d");

                const gradient =
                    context.createLinearGradient(
                        0,
                        0,
                        0,
                        360);

                gradient.addColorStop(
                    0,
                    "rgba(31,39,88,0.20)");

                gradient.addColorStop(
                    1,
                    "rgba(31,39,88,0.01)");

                new Chart(
                    canvas,
                    {
                        type: "line",

                        data: {
                            labels:
                                mensual.map(row => row.Mes),

                            datasets: [
                                {
                                    label: "Recaudación bruta",
                                    data:
                                        mensual.map(row => row.Bruto),
                                    borderColor:
                                        colors.primary,
                                    backgroundColor:
                                        gradient,
                                    borderWidth: 3,
                                    pointRadius: 3,
                                    pointHoverRadius: 6,
                                    pointBackgroundColor: "#ffffff",
                                    pointBorderColor: colors.primary,
                                    pointBorderWidth: 2,
                                    tension: 0.34,
                                    fill: true
                                },
                                {
                                    label: "Neto beneficiarios",
                                    data:
                                        mensual.map(row => row.Neto),
                                    borderColor:
                                        colors.green,
                                    backgroundColor:
                                        "transparent",
                                    borderWidth: 2,
                                    pointRadius: 2,
                                    pointHoverRadius: 5,
                                    tension: 0.34,
                                    fill: false
                                },
                                {
                                    label: "Retenciones",
                                    data:
                                        mensual.map(row => row.Retenciones),
                                    borderColor:
                                        colors.red,
                                    backgroundColor:
                                        "transparent",
                                    borderWidth: 2,
                                    borderDash: [6, 4],
                                    pointRadius: 2,
                                    pointHoverRadius: 5,
                                    tension: 0.34,
                                    fill: false
                                }
                            ]
                        },

                        options: {
                            responsive: true,
                            maintainAspectRatio: false,

                            interaction: {
                                mode: "index",
                                intersect: false
                            },

                            plugins: {
                                legend: {
                                    position: "top",
                                    align: "end",

                                    labels: {
                                        usePointStyle: true,
                                        pointStyle: "circle",
                                        padding: 18,
                                        boxWidth: 8,
                                        boxHeight: 8,

                                        font: {
                                            size: 11
                                        }
                                    }
                                },

                                tooltip: {
                                    backgroundColor: "#151b42",
                                    padding: 12,

                                    callbacks: {
                                        label: function (context) {
                                            return `${context.dataset.label}: ${money(context.parsed.y)}`;
                                        },

                                        afterBody: function (items) {

                                            const index =
                                                items[0]?.dataIndex;

                                            if (index === undefined) {
                                                return "";
                                            }

                                            return `${mensual[index].CantidadRecibos} recibos`;
                                        }
                                    }
                                }
                            },

                            scales: {
                                x: {
                                    grid: {
                                        display: false
                                    },

                                    border: {
                                        display: false
                                    }
                                },

                                y: {
                                    beginAtZero: true,

                                    grid: {
                                        color: colors.grid,
                                        drawTicks: false
                                    },

                                    border: {
                                        display: false
                                    },

                                    ticks: {
                                        padding: 10,

                                        callback: function (value) {
                                            return compactMoney(value);
                                        }
                                    }
                                }
                            }
                        }
                    });
            }


            // ==================================================
            // DISTRIBUCIÓN
            // ==================================================

            const hasDistribucion =
                distribucion.some(row =>
                    Number(row.Monto) > 0);

            if (!hasDistribucion) {

                showEmpty(
                    "chartDistribucion",
                    "emptyDistribucion");

            } else {

                new Chart(
                    document.getElementById(
                        "chartDistribucion"),
                    {
                        type: "doughnut",

                        data: {
                            labels:
                                distribucion.map(
                                    row => row.Concepto),

                            datasets: [{
                                data:
                                    distribucion.map(
                                        row => row.Monto),

                                backgroundColor:
                                    distributionColors,

                                borderColor: "#ffffff",
                                borderWidth: 3,
                                hoverOffset: 5
                            }]
                        },

                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: "70%",

                            plugins: {
                                legend: {
                                    display: false
                                },

                                tooltip: {
                                    backgroundColor: "#151b42",
                                    padding: 12,

                                    callbacks: {
                                        label: function (context) {

                                            const row =
                                                distribucion[
                                                    context.dataIndex];

                                            return `${row.Concepto}: ${money(row.Monto)} (${row.PorcentajeTotal}%)`;
                                        }
                                    }
                                }
                            }
                        }
                    });
            }


            // ==================================================
            // REGIONES
            // ==================================================

            const hasRegiones =
                regiones.some(row =>
                    Number(row.TotalRecaudado) > 0);

            if (!hasRegiones) {

                showEmpty(
                    "chartRegiones",
                    "emptyRegiones");

            } else {

                new Chart(
                    document.getElementById(
                        "chartRegiones"),
                    {
                        type: "bar",

                        data: {
                            labels:
                                regiones.map(
                                    row => row.Region),

                            datasets: [{
                                label: "Recaudación",
                                data:
                                    regiones.map(
                                        row => row.TotalRecaudado),

                                backgroundColor:
                                    regiones.map(
                                        (_, index) =>
                                            index === 0
                                                ? colors.red
                                                : colors.primary),

                                borderRadius: 6,
                                borderSkipped: false,
                                barThickness: 18
                            }]
                        },

                        options: {
                            indexAxis: "y",
                            responsive: true,
                            maintainAspectRatio: false,

                            plugins: {
                                legend: {
                                    display: false
                                },

                                tooltip: {
                                    backgroundColor: "#151b42",
                                    padding: 12,

                                    callbacks: {
                                        label: function (context) {

                                            const row =
                                                regiones[
                                                    context.dataIndex];

                                            return [
                                                `Recaudación: ${money(row.TotalRecaudado)}`,
                                                `Recibos: ${row.CantidadRecibos}`,
                                                `Iglesias: ${row.Iglesias}`
                                            ];
                                        }
                                    }
                                }
                            },

                            scales: {
                                x: {
                                    beginAtZero: true,

                                    grid: {
                                        color: colors.grid
                                    },

                                    border: {
                                        display: false
                                    },

                                    ticks: {
                                        callback: function (value) {
                                            return compactMoney(value);
                                        }
                                    }
                                },

                                y: {
                                    grid: {
                                        display: false
                                    },

                                    border: {
                                        display: false
                                    }
                                }
                            }
                        }
                    });
            }

        })();
    </script>
}