                                        <td class="text-end table-money">
                                            @FormatearDinero(iglesia.TotalAportado)
                                        </td>

                                        <td class="text-end">
                                            @iglesia.CantidadRecibos.ToString("N0", cultura)
                                        </td>

                                        <td class="text-end">
                                            @iglesia.MisionerosApoyados.ToString("N0", cultura)
                                        </td>
                                    </tr>
