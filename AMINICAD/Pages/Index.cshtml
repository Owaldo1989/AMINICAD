    </div>
</div>


@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js">
    </script>

    <script>
        (function () {

            const esVistaMensual =
                @Model.EsVistaMensual.ToString().ToLowerInvariant();

            const mostrarComparacionFlujo =
                @mostrarComparacionFlujo.ToString().ToLowerInvariant();

            const periodForm =
                document.getElementById("periodFilterForm");

            const modeInput =
                document.getElementById("modo");

            document
                .querySelectorAll("[data-period-mode]")
                .forEach(function (button) {

                    button.addEventListener(
                        "click",
                        function () {

                            if (!periodForm || !modeInput) {
                                return;
                            }

                            modeInput.value =
                                button.dataset.periodMode ?? "anio";

                            periodForm.submit();
                        });
                });

            const mensual =
                @Html.Raw(JsonSerializer.Serialize(
                        mensual.Select(x => new
                        {
                                Etiqueta = x.Mes,
                                Bruto = x.TotalBruto,
                                x.CantidadRecibos
                        })));

            const diario =
                @Html.Raw(JsonSerializer.Serialize(
                        diario.Select(x => new
                        {
                                Etiqueta = x.Dia.ToString(cultura),
                                Fecha = x.Fecha.ToString(
                                                "yyyy-MM-dd",
                                        CultureInfo.InvariantCulture),
                                x.Dia,
                                Bruto = x.TotalBruto,
                                x.CantidadRecibos
                         })));

            const flujoMensual =
                @Html.Raw(JsonSerializer.Serialize(
                        ingresosVsSalidas.Select(x => new
                        {
                                Etiqueta = x.Mes,
                                x.Ingresos,
                                x.Salidas,
                                x.PorcentajeEntregado,
                                x.CantidadPlanillas,
                                x.BeneficiariosPagados
                        })));

            const distribucionSalidas =
                @Html.Raw(JsonSerializer.Serialize(
                        distribucionSalidas.Select(x => new
                        {
                                x.TipoMision,
                                x.MontoEntregado,
                                x.PorcentajeTotal,
                                x.CantidadPlanillas,
                                x.CantidadBeneficiarios
                        })));

            const beneficiariosFondos =
                @Html.Raw(JsonSerializer.Serialize(
                        principalesBeneficiarios.Select(x => new
                        {
                                x.Misionero,
                                x.TipoMision,
                                x.MontoEntregado,
                                x.CantidadPlanillas,
                                UltimaEntrega = x.UltimaEntrega.HasValue
                                        ? x.UltimaEntrega.Value.ToString(
                                                "yyyy-MM-dd",
                                                CultureInfo.InvariantCulture)
                                        : null
                        })));

            const distribucion =
                @Html.Raw(JsonSerializer.Serialize(
                        distribucion.Select(x => new
                        {
                                x.Concepto,
                                x.Monto,
                                x.PorcentajeTotal
                        })));

            const regiones =
                @Html.Raw(JsonSerializer.Serialize(
                        regiones.Select(x => new
                        {
                                x.Region,
                                x.TotalRecaudado,
                                x.CantidadRecibos,
                                x.Iglesias
                        })));

            const seriePrincipal =
                esVistaMensual
                    ? diario
                    : mensual;

            const moneyFormatter =
                new Intl.NumberFormat(
                    "es-NI",
                    {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });

            const compactFormatter =
                new Intl.NumberFormat(
                    "es-NI",
                    {
                        notation: "compact",
                        maximumFractionDigits: 1
                    });

            const dateFormatter =
                new Intl.DateTimeFormat(
                    "es-NI",
                    {
                        day: "2-digit",
                        month: "2-digit",
                        year: "numeric",
                        timeZone: "UTC"
                    });

            const colors = {
                primary: "#1f2758",
                primaryLight: "#6470a6",
                red: "#d8292f",
                green: "#16803c",
                orange: "#c76b05",
                blue: "#1769aa",
                purple: "#7b3fc6",
                gray: "#98a2b3",
                grid: "#e8ebf2",
                muted: "#667085"
            };

            const distributionColors = [
                colors.primary,
                colors.red,
                colors.green,
                colors.blue,
                colors.orange,
                colors.purple,
                colors.primaryLight,
                colors.gray
            ];

            function money(value) {
                return `C$ ${moneyFormatter.format(value ?? 0)}`;
            }

            function compactMoney(value) {
                return `C$ ${compactFormatter.format(value ?? 0)}`;
            }

            function showEmpty(canvasId, emptyId) {

                const canvas =
                    document.getElementById(canvasId);

                const empty =
                    document.getElementById(emptyId);

                if (canvas) {
                    canvas.style.display = "none";
                }

                empty?.classList.add("show");
            }

            Chart.defaults.font.family =
                "Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif";

            Chart.defaults.color =
                colors.muted;


            // GRÁFICA PRINCIPAL
            const canvasPrincipal =
                document.getElementById(
                    "chartComportamientoMensual");

            const hasPeriodo =
                mostrarComparacionFlujo
                    ? flujoMensual.some(row =>
                        Number(row.Ingresos) > 0 ||
                        Number(row.Salidas) > 0)
                    : seriePrincipal.some(row =>
                        Number(row.Bruto) > 0);

            if (!hasPeriodo) {

                showEmpty(
                    "chartComportamientoMensual",
                    "emptyComportamiento");

            } else {

                new Chart(
                    canvasPrincipal,
                    {
                        type: "bar",

                        data: {
                            labels:
                                mostrarComparacionFlujo
                                    ? flujoMensual.map(
                                        row => row.Etiqueta)
                                    : seriePrincipal.map(
                                        row => row.Etiqueta),

                            datasets:
                                mostrarComparacionFlujo
                                    ? [
                                        {
                                            label: "Ingresos recaudados",
                                            data:
                                                flujoMensual.map(
                                                    row => row.Ingresos),
                                            borderColor: colors.primary,
                                            backgroundColor:
                                                "rgba(31,39,88,0.86)",
                                            hoverBackgroundColor:
                                                colors.primary,
                                            borderWidth: 1,
                                            borderRadius: 6,
                                            borderSkipped: false,
                                            maxBarThickness: 38,
                                            categoryPercentage: 0.78,
                                            barPercentage: 0.84
                                        },
                                        {
                                            label: "Egresos entregados",
                                            data:
                                                flujoMensual.map(
                                                    row => row.Salidas),
                                            borderColor: colors.green,
                                            backgroundColor:
                                                "rgba(22,128,60,0.78)",
                                            hoverBackgroundColor:
                                                colors.green,
                                            borderWidth: 1,
                                            borderRadius: 6,
                                            borderSkipped: false,
                                            maxBarThickness: 38,
                                            categoryPercentage: 0.78,
                                            barPercentage: 0.84
                                        }
                                    ]
                                    : [
                                        {
                                    label: "Recaudación bruta",
                                    data:
                                        seriePrincipal.map(
                                            row => row.Bruto),
                                    borderColor:
                                        colors.primary,
                                    backgroundColor:
                                        "rgba(31,39,88,0.86)",
                                    hoverBackgroundColor:
                                        colors.primary,
                                    borderWidth: 1,
                                    borderRadius: 6,
                                    borderSkipped: false,
                                    maxBarThickness:
                                        esVistaMensual ? 28 : 52,
                                    categoryPercentage: 0.78,
                                    barPercentage: 0.9
                                        }
                                    ]
                        },

                        options: {
                            responsive: true,
                            maintainAspectRatio: false,

                            interaction: {
                                mode: "index",
                                intersect: false
                            },

                            plugins: {
                                legend: {
                                    display: mostrarComparacionFlujo,
                                    position: "top",
                                    align: "end",

                                    labels: {
                                        usePointStyle: true,
                                        pointStyle: "rectRounded",
                                        padding: 16,
                                        boxWidth: 10,
                                        boxHeight: 10
                                    }
                                },

                                tooltip: {
                                    backgroundColor: "#151b42",
                                    padding: 12,

                                    callbacks: {
                                        title: function (items) {

                                            const index =
                                                items[0]?.dataIndex;

                                            if (index === undefined) {
                                                return "";
                                            }

                                            const row =
                                                mostrarComparacionFlujo
                                                    ? flujoMensual[index]
                                                    : seriePrincipal[index];

                                            if (esVistaMensual &&
                                                row.Fecha) {

                                                return `Día ${row.Dia} · ${dateFormatter.format(
                                                    new Date(
                                                        `${row.Fecha}T00:00:00Z`))}`;
                                            }

                                            return row.Etiqueta;
                                        },

                                        label: function (context) {
                                            return `${context.dataset.label}: ${money(context.parsed.y)}`;
                                        },

                                        afterBody: function (items) {

                                            const index =
                                                items[0]?.dataIndex;

                                            if (index === undefined) {
                                                return "";
                                            }

                                            if (mostrarComparacionFlujo) {
                                                const row =
                                                    flujoMensual[index];

                                                return [
                                                    `${row.CantidadPlanillas} planillas`,
                                                    `${row.BeneficiariosPagados} beneficiarios pagados`,
                                                    `${row.PorcentajeEntregado}% entregado respecto a ingresos`
                                                ];
                                            }

                                            return `${seriePrincipal[index].CantidadRecibos} recibos`;
                                        }
                                    }
                                }
                            },

                            scales: {
                                x: {
                                    grid: {
                                        display: false
                                    },

                                    border: {
                                        display: false
                                    },

                                    ticks: {
                                        autoSkip: true,
                                        maxTicksLimit:
                                            esVistaMensual ? 16 : 12,
                                        maxRotation: 0
                                    }
                                },

                                y: {
                                    beginAtZero: true,

                                    grid: {
                                        color: colors.grid,
                                        drawTicks: false
                                    },

                                    border: {
                                        display: false
                                    },

                                    ticks: {
                                        padding: 10,

                                        callback: function (value) {
                                            return compactMoney(value);
                                        }
                                    }
                                }
                            }
                        }
                    });
            }


            // DISTRIBUCIÓN DE SALIDAS POR TIPO DE MISIÓN
            const canvasDistribucionSalidas =
                document.getElementById(
                    "chartDistribucionSalidas");

            if (canvasDistribucionSalidas) {

                const hasDistribucionSalidas =
                    distribucionSalidas.some(row =>
                        Number(row.MontoEntregado) > 0);

                if (!hasDistribucionSalidas) {

                    showEmpty(
                        "chartDistribucionSalidas",
                        "emptyDistribucionSalidas");

                } else {

                    new Chart(
                        canvasDistribucionSalidas,
                        {
                            type: "doughnut",

                            data: {
                                labels:
                                    distribucionSalidas.map(
                                        row => row.TipoMision),

                                datasets: [{
                                    data:
                                        distribucionSalidas.map(
                                            row => row.MontoEntregado),
                                    backgroundColor:
                                        distributionColors,
                                    borderColor: "#ffffff",
                                    borderWidth: 3,
                                    hoverOffset: 5
                                }]
                            },

                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                cutout: "68%",

                                plugins: {
                                    legend: {
                                        display: false
                                    },

                                    tooltip: {
                                        backgroundColor: "#151b42",
                                        padding: 12,

                                        callbacks: {
                                            label: function (context) {
                                                const row =
                                                    distribucionSalidas[
                                                        context.dataIndex];

                                                return [
                                                    `${row.TipoMision}: ${money(row.MontoEntregado)}`,
                                                    `${row.PorcentajeTotal}% del total`,
                                                    `${row.CantidadBeneficiarios} beneficiarios`,
                                                    `${row.CantidadPlanillas} planillas`
                                                ];
                                            }
                                        }
                                    }
                                }
                            }
                        });
                }
            }


            // PRINCIPALES BENEFICIARIOS PAGADOS
            const canvasBeneficiariosFondos =
                document.getElementById(
                    "chartBeneficiariosFondos");

            if (canvasBeneficiariosFondos) {

                const hasBeneficiariosFondos =
                    beneficiariosFondos.some(row =>
                        Number(row.MontoEntregado) > 0);

                if (!hasBeneficiariosFondos) {

                    showEmpty(
                        "chartBeneficiariosFondos",
                        "emptyBeneficiariosFondos");

                } else {

                    new Chart(
                        canvasBeneficiariosFondos,
                        {
                            type: "bar",

                            data: {
                                labels:
                                    beneficiariosFondos.map(
                                        row => row.Misionero),

                                datasets: [{
                                    label: "Fondos entregados",
                                    data:
                                        beneficiariosFondos.map(
                                            row => row.MontoEntregado),
                                    backgroundColor:
                                        beneficiariosFondos.map(
                                            (_, index) =>
                                                index === 0
                                                    ? colors.green
                                                    : "rgba(31,39,88,0.82)"),
                                    borderRadius: 6,
                                    borderSkipped: false,
                                    maxBarThickness: 22
                                }]
                            },

                            options: {
                                indexAxis: "y",
                                responsive: true,
                                maintainAspectRatio: false,

                                plugins: {
                                    legend: {
                                        display: false
                                    },

                                    tooltip: {
                                        backgroundColor: "#151b42",
                                        padding: 12,

                                        callbacks: {
                                            label: function (context) {
                                                const row =
                                                    beneficiariosFondos[
                                                        context.dataIndex];

                                                const ultimaEntrega =
                                                    row.UltimaEntrega
                                                        ? dateFormatter.format(
                                                            new Date(
                                                                `${row.UltimaEntrega}T00:00:00Z`))
                                                        : "Sin fecha";

                                                return [
                                                    `Fondos: ${money(row.MontoEntregado)}`,
                                                    `Tipo: ${row.TipoMision}`,
                                                    `Planillas: ${row.CantidadPlanillas}`,
                                                    `Última entrega: ${ultimaEntrega}`
                                                ];
                                            }
                                        }
                                    }
                                },

                                scales: {
                                    x: {
                                        beginAtZero: true,
                                        grid: {
                                            color: colors.grid
                                        },
                                        border: {
                                            display: false
                                        },
                                        ticks: {
                                            callback: function (value) {
                                                return compactMoney(value);
                                            }
                                        }
                                    },
                                    y: {
                                        grid: {
                                            display: false
                                        },
                                        border: {
                                            display: false
                                        }
                                    }
                                }
                            }
                        });
                }
            }


            // DISTRIBUCIÓN
            const hasDistribucion =
                distribucion.some(row =>
                    Number(row.Monto) > 0);

            if (!hasDistribucion) {

                showEmpty(
                    "chartDistribucion",
                    "emptyDistribucion");

            } else {

                new Chart(
                    document.getElementById(
                        "chartDistribucion"),
                    {
                        type: "doughnut",

                        data: {
                            labels:
                                distribucion.map(
                                    row => row.Concepto),

                            datasets: [{
                                data:
                                    distribucion.map(
                                        row => row.Monto),

                                backgroundColor:
                                    distributionColors,

                                borderColor: "#ffffff",
                                borderWidth: 3,
                                hoverOffset: 5
                            }]
                        },

                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: "70%",

                            plugins: {
                                legend: {
                                    display: false
                                },

                                tooltip: {
                                    backgroundColor: "#151b42",
                                    padding: 12,

                                    callbacks: {
                                        label: function (context) {

                                            const row =
                                                distribucion[
                                                    context.dataIndex];

                                            return `${row.Concepto}: ${money(row.Monto)} (${row.PorcentajeTotal}%)`;
                                        }
                                    }
                                }
                            }
                        }
                    });
            }


            // REGIONES
            const hasRegiones =
                regiones.some(row =>
                    Number(row.TotalRecaudado) > 0);

            if (!hasRegiones) {

                showEmpty(
                    "chartRegiones",
                    "emptyRegiones");

            } else {

                new Chart(
                    document.getElementById(
                        "chartRegiones"),
                    {
                        type: "bar",

                        data: {
                            labels:
                                regiones.map(
                                    row => row.Region),

                            datasets: [{
                                label: "Recaudación",
                                data:
                                    regiones.map(
                                        row => row.TotalRecaudado),

                                backgroundColor:
                                    regiones.map(
                                        (_, index) =>
                                            index === 0
                                                ? colors.red
                                                : colors.primary),

                                borderRadius: 6,
                                borderSkipped: false,
                                barThickness: 18
                            }]
                        },

                        options: {
                            indexAxis: "y",
                            responsive: true,
                            maintainAspectRatio: false,

                            plugins: {
                                legend: {
                                    display: false
                                },

                                tooltip: {
                                    backgroundColor: "#151b42",
                                    padding: 12,

                                    callbacks: {
                                        label: function (context) {

                                            const row =
                                                regiones[
                                                    context.dataIndex];

                                            return [
                                                `Recaudación: ${money(row.TotalRecaudado)}`,
                                                `Recibos: ${row.CantidadRecibos}`,
                                                `Iglesias: ${row.Iglesias}`
                                            ];
                                        }
                                    }
                                }
                            },

                            scales: {
                                x: {
                                    beginAtZero: true,

                                    grid: {
                                        color: colors.grid
                                    },

                                    border: {
                                        display: false
                                    },

                                    ticks: {
                                        callback: function (value) {
                                            return compactMoney(value);
                                        }
                                    }
                                },

                                y: {
                                    grid: {
                                        display: false
                                    },

                                    border: {
                                        display: false
                                    }
                                }
                            }
                        }
                    });
            }

        })();
    </script>
}
