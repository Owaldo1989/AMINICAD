@page
@model AMINICAD.Pages.IndexModel

@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";

    var cultura = CultureInfo.GetCultureInfo("es-NI");
    var resumen = Model.Dashboard.Resumen;
    var calidad = Model.Dashboard.Calidad;
    var esVistaMensual = Model.EsVistaMensual;

    var etiquetaPeriodo =
        esVistaMensual
            ? $"{Model.NombreMesSeleccionado} {Model.AnioSeleccionado}"
            : Model.AnioSeleccionado.ToString(cultura);

    var textoCorte =
        Model.EsPeriodoEnCurso
            ? $"Datos registrados hasta el {Model.FechaFinal:dd/MM/yyyy}"
            : $"Período cerrado al {Model.FechaFinal:dd/MM/yyyy}";

    var mensual = Model.Dashboard.Mensual
        .OrderBy(x => x.Periodo)
        .ToList();

    var diario = Model.Dashboard.Diario
        .OrderBy(x => x.Fecha)
        .ToList();

    var ingresosVsSalidas = Model.IngresosVsSalidas
        .OrderBy(x => x.Periodo)
        .ToList();

    var distribucionSalidas = Model.Dashboard.DistribucionSalidas
        .Where(x => x.MontoEntregado > 0)
        .OrderByDescending(x => x.MontoEntregado)
        .ToList();

    var principalesBeneficiarios = Model.Dashboard.PrincipalesBeneficiarios
        .Where(x => x.MontoEntregado > 0)
        .OrderByDescending(x => x.MontoEntregado)
        .Take(10)
        .ToList();

    var mostrarComparacionFlujo =
        !esVistaMensual
        && Model.ComparacionIngresosSalidasDisponible;

    var totalFondosEntregados =
        ingresosVsSalidas.Sum(x => x.Salidas);

    var cantidadPlanillasPeriodo =
        ingresosVsSalidas.Sum(x => x.CantidadPlanillas);

    var cantidadBeneficiariosPagados =
        distribucionSalidas.Sum(x => x.CantidadBeneficiarios);

    var promedioNetoRecibido =
        cantidadBeneficiariosPagados > 0
            ? totalFondosEntregados / cantidadBeneficiariosPagados
            : 0m;

    var mesesConFlujo =
        ingresosVsSalidas.Count(x => x.Ingresos > 0 || x.Salidas > 0);

    var distribucion = Model.Dashboard.Distribucion
        .Where(x => x.Monto > 0)
        .OrderByDescending(x => x.Monto)
        .Take(8)
        .ToList();

    var regiones = Model.Dashboard.Regiones
        .Where(x => x.TotalRecaudado > 0)
        .OrderByDescending(x => x.TotalRecaudado)
        .Take(10)
        .ToList();

    var distritos = Model.Dashboard.Distritos
        .Where(x => x.TotalRecaudado > 0)
        .OrderByDescending(x => x.TotalRecaudado)
        .Take(8)
        .ToList();

    var misioneros = Model.Dashboard.Misioneros
        .Where(x => x.TotalBruto > 0)
        .OrderByDescending(x => x.TotalBruto)
        .Take(8)
        .ToList();

    var iglesias = Model.Dashboard.Iglesias
        .Where(x => x.TotalAportado > 0)
        .OrderByDescending(x => x.TotalAportado)
        .Take(8)
        .ToList();

    var mesesConMovimiento =
        mensual.Count(x => x.TotalBruto > 0);

    var diasConMovimiento =
        diario.Count(x => x.TotalBruto > 0);

    var mejorMes = mensual
        .Where(x => x.TotalBruto > 0)
        .OrderByDescending(x => x.TotalBruto)
        .FirstOrDefault();

    var mejorDia = diario
        .Where(x => x.TotalBruto > 0)
        .OrderByDescending(x => x.TotalBruto)
        .FirstOrDefault();

    var totalIncidencias =
        calidad.RecibosSinIglesia +
        calidad.RecibosSinMisionero +
        calidad.RecibosSinRegion +
        calidad.RecibosSinDistrito +
        calidad.FilasSinConcepto +
        calidad.ConceptosNoClasificados +
        calidad.RecibosDescuadrados;

    string FormatearDinero(decimal valor)
    {
        return $"C$ {valor.ToString("N2", cultura)}";
    }

    string FormatearFecha(DateTime? fecha)
    {
        return fecha.HasValue
            ? fecha.Value.ToString("dd/MM/yyyy", cultura)
            : "Sin fecha";
    }
}

<div class="dashboard-container">

    <!-- ENCABEZADO -->
    <div class="page-header">

        <div>
            <div class="page-pretitle">
                Resumen ejecutivo
            </div>

            <h1 class="page-title">
                @Model.TituloPeriodo
            </h1>

            <p class="page-description">
                @(esVistaMensual
                    ? "Análisis operativo del mes seleccionado: recaudación, distribución, territorios y beneficiarios."
                    : "Análisis ejecutivo del año: recaudación, distribución, territorios y beneficiarios.")
            </p>
        </div>

        <div class="page-actions">

            <div class="dashboard-period">
                <i class="bi bi-calendar3"></i>

                <div>
                    <span>Período consultado</span>

                    <strong>
                        @Model.FechaInicial.ToString("dd/MM/yyyy")
                        —
                        @Model.FechaFinal.ToString("dd/MM/yyyy")
                    </strong>

                    <small class="text-muted">
                        @textoCorte
                    </small>
                </div>
            </div>

            <form method="get"
                  id="periodFilterForm"
                  class="d-flex flex-wrap align-items-end gap-2 bg-white border rounded-3 p-2 shadow-sm">

                <input type="hidden"
                       id="modo"
                       name="modo"
                       value="@Model.ModoSeleccionado" />

                @if (Model.IdRegion.HasValue)
                {
                    <input type="hidden"
                           name="idRegion"
                           value="@Model.IdRegion.Value" />
                }

                @if (Model.IdDistrito.HasValue)
                {
                    <input type="hidden"
                           name="idDistrito"
                           value="@Model.IdDistrito.Value" />
                }

                @if (Model.IdMisionero.HasValue)
                {
                    <input type="hidden"
                           name="idMisionero"
                           value="@Model.IdMisionero.Value" />
                }

                @if (Model.IdIglesia.HasValue)
                {
                    <input type="hidden"
                           name="idIglesia"
                           value="@Model.IdIglesia.Value" />
                }

                @if (Model.IdTipoMision.HasValue)
                {
                    <input type="hidden"
                           name="idTipoMision"
                           value="@Model.IdTipoMision.Value" />
                }

                <div>
                    <label class="form-label small text-muted mb-1">
                        Vista
                    </label>

                    <div class="btn-group d-flex"
                         role="group"
                         aria-label="Tipo de período">

                        <button type="button"
                                class="btn btn-sm @(esVistaMensual ? "btn-outline-secondary" : "btn-primary")"
                                data-period-mode="anio">
                            <i class="bi bi-calendar3 me-1"></i>
                            Anual
                        </button>

                        <button type="button"
                                class="btn btn-sm @(esVistaMensual ? "btn-primary" : "btn-outline-secondary")"
                                data-period-mode="mes">
                            <i class="bi bi-calendar2-week me-1"></i>
                            Mensual
                        </button>
                    </div>
                </div>

                <div>
                    <label for="anio"
                           class="form-label small text-muted mb-1">
                        Año
                    </label>

                    <select id="anio"
                            name="anio"
                            class="form-select form-select-sm"
                            onchange="this.form.submit()">

                        @foreach (var anio in Model.OpcionesAnio)
                        {
                            <option value="@anio"
                                    selected="@(anio == Model.AnioSeleccionado ? "selected" : null)">
                                @anio
                            </option>
                        }
                    </select>
                </div>

                @if (esVistaMensual)
                {
                    <div>
                        <label for="mes"
                               class="form-label small text-muted mb-1">
                            Mes
                        </label>

                        <select id="mes"
                                name="mes"
                                class="form-select form-select-sm"
                                onchange="this.form.submit()">

                            @foreach (var mes in Model.OpcionesMes)
                            {
                                <option value="@mes"
                                        disabled="@(Model.MesEsFuturo(mes) ? "disabled" : null)"
                                        selected="@(mes == Model.MesSeleccionado ? "selected" : null)">
                                    @Model.ObtenerNombreMesOpcion(mes)
                                </option>
                            }
                        </select>
                    </div>
                }
                else
                {
                    <input type="hidden"
                           name="mes"
                           value="@Model.MesSeleccionado" />
                }
            </form>
        </div>
    </div>


    <!-- KPI PRINCIPALES -->
    <div class="row g-3 mb-3">

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#1f2758; --kpi-soft:#eef0f8;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-cash-stack"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            @(esVistaMensual
                                ? $"Ingresos recaudados en {Model.NombreMesSeleccionado}"
                                : "Ingresos recaudados")
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.TotalBruto)
                        </div>

                        <div class="kpi-note">
                            Ingreso ·
                            @resumen.CantidadRecibos.ToString("N0", cultura)
                            recibos registrados
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#c76b05; --kpi-soft:#fff4df;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-cash-coin"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            @(esVistaMensual
                                ? $"Egresos entregados en {Model.NombreMesSeleccionado}"
                                : "Egresos entregados")
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @(Model.ComparacionIngresosSalidasDisponible
                                ? FormatearDinero(totalFondosEntregados)
                                : "—")
                        </div>

                        <div class="kpi-note">
                            @(Model.ComparacionIngresosSalidasDisponible
                                ? $"Egreso · {cantidadPlanillasPeriodo.ToString("N0", cultura)} planillas terminadas"
                                : "No aplica con filtros territoriales")
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#087f73; --kpi-soft:#e8f7f5;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-wallet2"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            Promedio neto recibido
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @(Model.ComparacionIngresosSalidasDisponible
                                ? FormatearDinero(promedioNetoRecibido)
                                : "—")
                        </div>

                        <div class="kpi-note">
                            @(Model.ComparacionIngresosSalidasDisponible
                                ? $"Egreso promedio · {cantidadBeneficiariosPagados.ToString("N0", cultura)} beneficiarios pagados"
                                : "No aplica con filtros territoriales")
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#16803c; --kpi-soft:#eaf7ef;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-person-check"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            @(esVistaMensual
                                ? "Neto calculado del mes"
                                : "Neto calculado de ingresos")
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.NetoBeneficiarios)
                        </div>

                        <div class="kpi-note positive">
                            @resumen.PorcentajeNeto.ToString("N2", cultura)%
                            de lo recaudado; no representa lo entregado
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#d8292f; --kpi-soft:#fdeced;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-pie-chart"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            @(esVistaMensual
                                ? "Retenciones del mes"
                                : "Retenciones del año")
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.TotalRetenciones)
                        </div>

                        <div class="kpi-note">
                            @resumen.PorcentajeRetenciones.ToString("N2", cultura)%
                            del total
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#1769aa; --kpi-soft:#e9f3fb;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-bank2"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            Iglesias / aportantes
                        </div>

                        <div class="kpi-value">
                            @resumen.CantidadIglesias.ToString("N0", cultura)
                        </div>

                        <div class="kpi-note">
                            @resumen.CantidadDistritos.ToString("N0", cultura)
                            distritos activos
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#7b3fc6; --kpi-soft:#f2ebfb;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-person-vcard"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            Beneficiarios
                        </div>

                        <div class="kpi-value">
                            @resumen.CantidadMisioneros.ToString("N0", cultura)
                        </div>

                        <div class="kpi-note">
                            @(esVistaMensual
                                ? "Apoyados durante el mes"
                                : "Misioneros y proyectos")
                        </div>
                    </div>
                </div>
            </article>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <article class="kpi-card"
                     style="--kpi-accent:#c76b05; --kpi-soft:#fff4df;">
                <div class="kpi-card-body">
                    <div class="kpi-icon">
                        <i class="bi bi-calculator"></i>
                    </div>

                    <div class="kpi-content">
                        <div class="kpi-label">
                            Promedio por aporte
                        </div>

                        <div class="kpi-value kpi-value-responsive">
                            @FormatearDinero(resumen.PromedioAporte)
                        </div>

                        <div class="kpi-note">
                            Mediana:
                            @FormatearDinero(resumen.MedianaAporte)
                        </div>
                    </div>
                </div>
            </article>
        </div>
    </div>


    <!-- COMPORTAMIENTO + DISTRIBUCIÓN -->
    <div class="row g-3 mb-3">

        <div class="col-12 col-xl-8">
            <section class="dashboard-card">
                <header class="dashboard-card-header">
                    <div class="card-heading">
                        <h2>
                            @(mostrarComparacionFlujo
                                ? "Ingresos recaudados vs. egresos entregados"
                                : esVistaMensual
                                    ? $"Recaudación bruta diaria de {Model.NombreMesSeleccionado}"
                                    : "Recaudación bruta mensual")
                        </h2>

                        <p>
                            @(mostrarComparacionFlujo
                                ? "Comparación mensual de la recaudación bruta y las salidas por planillas terminadas."
                                : esVistaMensual
                                    ? "Total bruto recaudado por día."
                                    : "Total bruto recaudado por mes.")
                        </p>
                    </div>

                    <div class="card-header-meta">
                        @if (mostrarComparacionFlujo)
                        {
                            <span class="card-badge">
                                @mesesConFlujo meses con flujo
                            </span>

                            <span class="card-highlight">
                                Entregado:
                                <strong>@FormatearDinero(totalFondosEntregados)</strong>
                            </span>
                        }
                        else if (esVistaMensual)
                        {
                            <span class="card-badge">
                                @diasConMovimiento días con movimientos
                            </span>

                            @if (mejorDia is not null)
                            {
                                <span class="card-highlight">
                                    Mejor día:
                                    <strong>@mejorDia.Dia</strong>
                                </span>
                            }
                        }
                        else
                        {
                            <span class="card-badge">
                                @mesesConMovimiento meses con movimientos
                            </span>

                            @if (mejorMes is not null)
                            {
                                <span class="card-highlight">
                                    Mejor mes:
                                    <strong>@mejorMes.Mes</strong>
                                </span>
                            }
                        }
                    </div>
                </header>

                <div class="dashboard-card-body">
                    <div class="chart-container chart-large">
                        <canvas id="chartComportamientoMensual">
                        </canvas>

                        <div id="emptyComportamiento"
                             class="chart-empty">
                            <div class="chart-empty-icon">
                                <i class="bi bi-graph-up"></i>
                            </div>

                            <strong>
                                No hay información para el período
                            </strong>

                            <span>
                                @(mostrarComparacionFlujo
                                    ? $"No existen ingresos ni fondos entregados para {etiquetaPeriodo}."
                                    : esVistaMensual
                                        ? $"El noveno resultado del procedimiento no devolvió movimientos diarios para {etiquetaPeriodo}."
                                        : $"El procedimiento no devolvió movimientos mensuales para {etiquetaPeriodo}.")
                            </span>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="dashboard-card">
                <header class="dashboard-card-header">
                    <div class="card-heading">
                        <h2>
                            Distribución de los fondos
                        </h2>

                        <p>
                            Conceptos aplicados durante @etiquetaPeriodo
                        </p>
                    </div>
                </header>

                <div class="dashboard-card-body">
                    <div class="distribution-chart">
                        <div class="distribution-canvas">
                            <canvas id="chartDistribucion">
                            </canvas>

                            <div id="emptyDistribucion"
                                 class="chart-empty chart-empty-small">
                                <strong>
                                    Sin distribución
                                </strong>
                            </div>
                        </div>

                        <div class="distribution-total">
                            <span>
                                Total distribuido
                            </span>

                            <strong>
                                @FormatearDinero(resumen.TotalDistribuido)
                            </strong>
                        </div>
                    </div>

                    <div class="distribution-list">
                        @foreach (var item in distribucion.Take(6))
                        {
                            <div class="distribution-row">
                                <div class="distribution-row-copy">
                                    <span class="distribution-marker">
                                    </span>

                                    <div>
                                        <strong>
                                            @item.Concepto
                                        </strong>

                                        <span>
                                            @item.CantidadRecibos.ToString("N0", cultura)
                                            recibos
                                        </span>
                                    </div>
                                </div>

                                <div class="distribution-row-value">
                                    <strong>
                                        @FormatearDinero(item.Monto)
                                    </strong>

                                    <span>
                                        @item.PorcentajeTotal.ToString("N2", cultura)%
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </section>
        </div>
    </div>


    @if (Model.ComparacionIngresosSalidasDisponible)
    {
        <!-- SALIDAS DE FONDOS + BENEFICIARIOS PAGADOS -->
        <div class="row g-3 mb-3">

            <div class="col-12 col-xl-5">
                <section class="dashboard-card">
                    <header class="dashboard-card-header">
                        <div class="card-heading">
                            <h2>Distribución de fondos entregados</h2>

                            <p>
                                Salidas por tipo de misión durante @etiquetaPeriodo
                            </p>
                        </div>

                        <span class="card-badge">
                            @distribucionSalidas.Count categorías
                        </span>
                    </header>

                    <div class="dashboard-card-body">
                        <div class="distribution-chart">
                            <div class="distribution-canvas">
                                <canvas id="chartDistribucionSalidas"></canvas>

                                <div id="emptyDistribucionSalidas"
                                     class="chart-empty chart-empty-small">
                                    <strong>Sin fondos entregados</strong>
                                </div>
                            </div>

                            <div class="distribution-total">
                                <span>Total entregado</span>
                                <strong>@FormatearDinero(totalFondosEntregados)</strong>
                            </div>
                        </div>

                        <div class="distribution-list">
                            @foreach (var item in distribucionSalidas.Take(6))
                            {
                                <div class="distribution-row">
                                    <div class="distribution-row-copy">
                                        <span class="distribution-marker"></span>

                                        <div>
                                            <strong>@item.TipoMision</strong>
                                            <span>
                                                @item.CantidadBeneficiarios beneficiarios ·
                                                @item.CantidadPlanillas planillas
                                            </span>
                                        </div>
                                    </div>

                                    <div class="distribution-row-value">
                                        <strong>@FormatearDinero(item.MontoEntregado)</strong>
                                        <span>@item.PorcentajeTotal.ToString("N2", cultura)%</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            </div>

            <div class="col-12 col-xl-7">
                <section class="dashboard-card">
                    <header class="dashboard-card-header">
                        <div class="card-heading">
                            <h2>Principales beneficiarios pagados</h2>

                            <p>
                                Top 10 por fondos recibidos durante @etiquetaPeriodo
                            </p>
                        </div>

                        <span class="card-badge">
                            @principalesBeneficiarios.Count beneficiarios
                        </span>
                    </header>

                    <div class="dashboard-card-body">
                        <div class="chart-container chart-regions">
                            <canvas id="chartBeneficiariosFondos"></canvas>

                            <div id="emptyBeneficiariosFondos"
                                 class="chart-empty">
                                <div class="chart-empty-icon">
                                    <i class="bi bi-people"></i>
                                </div>

                                <strong>No hay beneficiarios pagados</strong>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    }


    <!-- REGIONES + CALIDAD -->
    <div class="row g-3 mb-3">

        <div class="col-12 col-xl-8">
            <section class="dashboard-card">
                <header class="dashboard-card-header">
                    <div class="card-heading">
                        <h2>
                            Recaudación por región
                        </h2>

                        <p>
                            Participación territorial durante @etiquetaPeriodo
                        </p>
                    </div>

                    <span class="card-badge">
                        @resumen.CantidadRegiones regiones
                    </span>
                </header>

                <div class="dashboard-card-body">
                    <div class="chart-container chart-regions">
                        <canvas id="chartRegiones">
                        </canvas>

                        <div id="emptyRegiones"
                             class="chart-empty">
                            <div class="chart-empty-icon">
                                <i class="bi bi-geo-alt"></i>
                            </div>

                            <strong>
                                No hay regiones para mostrar
                            </strong>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="dashboard-card">
                <header class="dashboard-card-header">
                    <div class="card-heading">
                        <h2>
                            Calidad de información
                        </h2>

                        <p>
                            Validaciones administrativas de @etiquetaPeriodo
                        </p>
                    </div>

                    @if (totalIncidencias > 0)
                    {
                        <span class="badge-status badge-status-warning">
                            @totalIncidencias incidencias
                        </span>
                    }
                    else
                    {
                        <span class="badge-status badge-status-success">
                            Sin incidencias
                        </span>
                    }
                </header>

                <div class="dashboard-card-body">
                    <div class="quality-list">

                        <div class="quality-item">
                            <div class="quality-icon">
                                <i class="bi bi-bank"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin iglesia</span>
                                <strong>@calidad.RecibosSinIglesia</strong>
                            </div>
                        </div>

                        <div class="quality-item">
                            <div class="quality-icon">
                                <i class="bi bi-person-x"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin beneficiario</span>
                                <strong>@calidad.RecibosSinMisionero</strong>
                            </div>
                        </div>

                        <div class="quality-item">
                            <div class="quality-icon">
                                <i class="bi bi-geo"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin región</span>
                                <strong>@calidad.RecibosSinRegion</strong>
                            </div>
                        </div>

                        <div class="quality-item">
                            <div class="quality-icon">
                                <i class="bi bi-signpost-split"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos sin distrito</span>
                                <strong>@calidad.RecibosSinDistrito</strong>
                            </div>
                        </div>

                        <div class="quality-item">
                            <div class="quality-icon">
                                <i class="bi bi-tags"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Conceptos no clasificados</span>
                                <strong>@calidad.ConceptosNoClasificados</strong>
                            </div>
                        </div>

                        <div class="quality-item quality-item-important">
                            <div class="quality-icon">
                                <i class="bi bi-exclamation-triangle"></i>
                            </div>

                            <div class="quality-copy">
                                <span>Recibos descuadrados</span>
                                <strong>@calidad.RecibosDescuadrados</strong>
                            </div>
                        </div>
                    </div>

                    @if (calidad.RecibosDescuadrados > 0)
                    {
                        <div class="quality-warning">
                            <i class="bi bi-exclamation-circle"></i>

                            <div>
                                <strong>
                                    Diferencia encontrada
                                </strong>

                                <span>
                                    @FormatearDinero(calidad.DiferenciaTotal)
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>


    <!-- DISTRITOS -->
    <section class="dashboard-card mb-3">
        <header class="dashboard-card-header">
            <div class="card-heading">
                <h2>
                    Distritos con mayor recaudación
                </h2>

                <p>
                    Principales resultados territoriales de @etiquetaPeriodo
                </p>
            </div>

            <span class="card-badge">
                Top @distritos.Count
            </span>
        </header>

        <div class="dashboard-table-wrapper">
            <table class="table dashboard-table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Distrito</th>
                        <th>Región</th>
                        <th class="text-end">Recaudado</th>
                        <th class="text-end">Recibos</th>
                        <th class="text-end">Iglesias</th>
                        <th class="text-end">Promedio</th>
                        <th>Último aporte</th>
                    </tr>
                </thead>

                <tbody>
                    @if (distritos.Count > 0)
                    {
                        var posicionDistrito = 0;

                        foreach (var distrito in distritos)
                        {
                            posicionDistrito++;

                            <tr>
                                <td>
                                    <span class="ranking-position">
                                        @posicionDistrito
                                    </span>
                                </td>

                                <td>
                                    <div class="entity-name">
                                        @distrito.Distrito
                                    </div>
                                </td>

                                <td>
                                    <span class="table-subtitle">
                                        @distrito.Region
                                    </span>
                                </td>

                                <td class="text-end table-money">
                                    @FormatearDinero(distrito.TotalRecaudado)
                                </td>

                                <td class="text-end">
                                    @distrito.CantidadRecibos.ToString("N0", cultura)
                                </td>

                                <td class="text-end">
                                    @distrito.Iglesias.ToString("N0", cultura)
                                </td>

                                <td class="text-end">
                                    @FormatearDinero(distrito.PromedioAporte)
                                </td>

                                <td>
                                    @FormatearFecha(distrito.UltimoAporte)
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8"
                                class="table-empty">
                                No hay distritos disponibles
                                para el período seleccionado.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>


    <!-- MISIONEROS E IGLESIAS -->
    <div class="row g-3">

        <div class="col-12 col-xxl-6">
            <section class="dashboard-card">
                <header class="dashboard-card-header">
                    <div class="card-heading">
                        <h2>
                            Principales beneficiarios
                        </h2>

                        <p>
                            Misioneros y proyectos con mayor recaudación en @etiquetaPeriodo
                        </p>
                    </div>

                    <span class="card-badge">
                        Top @misioneros.Count
                    </span>
                </header>

                <div class="dashboard-table-wrapper">
                    <table class="table dashboard-table dashboard-table-compact mb-0">
                        <thead>
                            <tr>
                                <th>Beneficiario</th>
                                <th class="text-end">Bruto</th>
                                <th class="text-end">Neto</th>
                                <th class="text-end">Retenciones</th>
                                <th class="text-end">Recibos</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (misioneros.Count > 0)
                            {
                                foreach (var misionero in misioneros)
                                {
                                    <tr>
                                        <td>
                                            <div class="table-entity">
                                                <div class="entity-avatar entity-avatar-blue">
